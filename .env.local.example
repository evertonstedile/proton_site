# ─── Supabase ───────────────────────────────────────────────────────────────
# Copie para `.env.local` (já no .gitignore) e preencha. Sem isto, a app usa
# stubs e NÃO toca o Supabase.

# URL do projeto (ex.: https://xxxxxxxx.supabase.co)
SUPABASE_URL=

# Leitura de OBRAS (server-side). Use a anon key (com policy SELECT em `obras`)
# OU a service role. NÃO prefixar com NEXT_PUBLIC se for service role.
SUPABASE_ANON_KEY=

# Escrita de LEADS (Server Action, server-only). Service role.
# Mantém-se ociosa até LEADS_WRITE_ENABLED=true (guard-rail B5).
SUPABASE_SERVICE_ROLE_KEY=

# Liga a escrita de leads no Supabase. Deixe "false" até liberação explícita.
LEADS_WRITE_ENABLED=false

# ─── Site ───────────────────────────────────────────────────────────────────
# Domínio final (registro.br). Hoje placeholder em lib/site.ts.
# Ex.: https://protonengenharia.com.br
NEXT_PUBLIC_SITE_URL=
