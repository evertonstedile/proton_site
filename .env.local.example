# Copie para `.env.local` (já no .gitignore). Sem isto, valores placeholder de lib/site.ts.

# Domínio final (registro.br). Ex.: https://protonsc.com.br
NEXT_PUBLIC_SITE_URL=https://protonsc.com.br

# ─── Contato ──────────────────────────────────────────────────────────────
# WhatsApp: só dígitos, com DDI(55)+DDD. Ex.: 5547999999999
NEXT_PUBLIC_WHATSAPP=

# E-mail de contato exibido no site
NEXT_PUBLIC_CONTACT_EMAIL=

# Web3Forms: chave de acesso (pública) para o form enviar e-mail.
# Gere grátis em https://web3forms.com com o e-mail destino. Sem ela, o form
# fica em modo demonstração e direciona ao WhatsApp.
NEXT_PUBLIC_WEB3FORMS_KEY=
